{
  "name": "desktop",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "homepage": "https://electron-vite.org",
  "author": "example.com",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "rebuild:native": "node scripts/rebuild-better-sqlite3.cjs",
    "setup": "pnpm install && pnpm run rebuild:native",
    "dev": "pnpm run rebuild:native && electron-vite dev",
    "build": "pnpm run rebuild:native && npm run typecheck && electron-vite build",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "postinstall": "node scripts/rebuild-better-sqlite3.cjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "pnpm run rebuild:native && electron-vite build && electron-builder --mac",
    "build:linux": "pnpm run rebuild:native && electron-vite build && electron-builder --linux",
    "test": "tsx --tsconfig tsconfig.web.json --test src/renderer/src/lib/i18n.test.ts src/renderer/src/lib/settings.test.ts src/renderer/src/lib/theme.test.ts src/renderer/src/lib/errors.test.ts src/renderer/src/lib/chat-messages.test.ts src/renderer/src/lib/chat-tools.test.ts src/renderer/src/lib/chat-media.test.ts src/renderer/src/components/ai-elements/rich-content.test.ts && tsx --tsconfig tsconfig.node.json --test src/main/server/index.test.ts src/main/lib/providers.test.ts src/main/lib/chat-tools.test.ts src/main/lib/sandbox-agents.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/mcp": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/react": "catalog:",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@hono/node-server": "^1.13.7",
    "@openai/agents": "catalog:",
    "@openai/agents-extensions": "catalog:",
    "ai": "catalog:",
    "better-sqlite3": "catalog:",
    "drizzle-orm": "catalog:",
    "electron-updater": "^6.3.9",
    "hono": "^4.6.12",
    "motion": "catalog:",
    "sonner": "catalog:",
    "tailwind-variants": "^3.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "catalog:",
    "electron": "catalog:",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.15",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3"
    ]
  }
}
